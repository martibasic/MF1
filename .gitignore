# Default: keep everything private unless explicitly allowed below.
*
**/*

# Public project skeleton required for Quarto/GitHub Pages publishing.
!.gitignore
!.github/
!.github/workflows/
!.github/workflows/publish.yml
!_quarto.yml
!index.qmd
!custom.css

# Public content chapters.
!vjezba_*.qmd

# Local project/output folders stay private.
/.quarto/
/_site/
/_book/
/.obsidian/
/private/

# Common local artifacts.
*.log
quarto_*.log
*.pyc
**/*.quarto_ipynb
.DS_Store
